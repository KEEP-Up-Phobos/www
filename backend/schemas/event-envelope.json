{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventEnvelope",
  "description": "Compact event envelope used for ingestion and broker messages.",
  "type": "object",
  "required": ["type", "event_id", "ts", "location", "version"],
  "properties": {
    "type": {
      "type": "string",
      "description": "Envelope type (e.g., \"event:created\", \"event:updated\")."
    },
    "event_id": {
      "type": "string",
      "description": "Canonical event identifier (UUID or provider-scoped id)."
    },
    "version": {
      "type": "string",
      "description": "Envelope schema version (semver or date tag).",
      "default": "1.0"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the event was observed or emitted."
    },
    "source": {
      "type": "string",
      "description": "Optional source/provider name (e.g., ticketmaster, sympla)."
    },
    "location": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "lat": {"type": "number", "minimum": -90, "maximum": 90},
        "lon": {"type": "number", "minimum": -180, "maximum": 180},
        "city": {"type": "string"},
        "country": {"type": "string"}
      }
    },
    "payload": {
      "type": ["object", "null"],
      "description": "Optional denormalized event payload (title, venue, start_time, url, tickets) stored as small JSONB on Postgres when needed."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional routing/metadata: e.g., {" + "\"radius_m\": 1000, \"tags\": [\"music\"]}" 
    }
  },
  "additionalProperties": false
}
