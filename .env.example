# ===== KEEP-Up Fetcher Configuration =====

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=keepup_events
DB_USER=keepup_user
DB_PASSWORD=keepup_secret

# --- AI (OpenRouter) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
AI_PRIMARY_MODEL=deepseek/deepseek-chat
AI_FALLBACK_MODEL=mistralai/mistral-7b-instruct:free

# --- Foursquare ---
# Get your key at https://foursquare.com/developers
FOURSQUARE_API_KEY=fsq-your-key-here

# --- Ticketmaster ---
# Get your key at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=your-key-here

# --- Viagogo (optional) ---
VIAGOGO_API_KEY=

# --- Admin API ---
ADMIN_API_KEY=change_me_in_production

# --- Sweep Settings ---
INITIAL_RADIUS_KM=10
RADIUS_STEP_KM=15
MAX_RADIUS_KM=200
SWEEP_DELAY_SECONDS=30
API_CALL_DELAY=2.0
CITIES_PER_CYCLE=3
MEMORY_CAP_MB=128

# --- MariaDB (legacy) ---
MARIADB_ROOT_PASSWORD=root_secret
MARIADB_PASSWORD=keepup_secret
